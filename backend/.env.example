# ─────────────────────────────────────────────────────────────────────────────
# Home Sale Helper — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI, Transaction mode, port 6543)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for Prisma migrations (Session mode, port 5432)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"

# ── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── AI / ML ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
GOOGLE_CLOUD_API_KEY="AIza..."
GOOGLE_CLOUD_PROJECT_ID="your-gcp-project-id"

# ── Marketplace APIs ─────────────────────────────────────────────────────────
EBAY_CLIENT_ID="your-ebay-client-id"
EBAY_CLIENT_SECRET="your-ebay-client-secret"
EBAY_ENVIRONMENT="sandbox"   # sandbox | production

FACEBOOK_APP_ID="your-fb-app-id"
FACEBOOK_APP_SECRET="your-fb-app-secret"

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Notifications (Expo Push — no Firebase needed) ───────────────────────────
# Optional: avoids rate-limiting in production. Generate at expo.dev → Account → Access Tokens
EXPO_ACCESS_TOKEN=""

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"
# PostHog project write key — used at runtime by the Fastify plugin for event capture
POSTHOG_API_KEY="phc_..."
POSTHOG_HOST="https://app.posthog.com"
# PostHog management API — needed only to run scripts/setup-posthog-dashboards.sh
# Generate at: app.posthog.com → Settings → Personal API keys (scope: project:write)
POSTHOG_PERSONAL_API_KEY="phx_..."
# Numeric project ID visible in the PostHog URL: /project/<ID>/...
POSTHOG_PROJECT_ID="123456"

# PostHog Management API — required only to run scripts/setup-posthog-dashboards.sh
# NOT needed at app runtime. Generate at app.posthog.com → Settings → Personal API keys (scope: project:write)
POSTHOG_PERSONAL_API_KEY="phx_..."
# Found in PostHog URL: /project/<POSTHOG_PROJECT_ID>/...
POSTHOG_PROJECT_ID="123456"

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
MARKETPLACE_TOKEN_ENCRYPTION_KEY="32-byte-hex-key-for-aes-256"
