# ─────────────────────────────────────────────────────────────────────────────
# Home Sale Helper — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── AI / ML ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
GOOGLE_CLOUD_API_KEY="AIza..."
GOOGLE_CLOUD_PROJECT_ID="your-gcp-project-id"

# ── Marketplace APIs ─────────────────────────────────────────────────────────
EBAY_CLIENT_ID="your-ebay-client-id"
EBAY_CLIENT_SECRET="your-ebay-client-secret"
EBAY_ENVIRONMENT="sandbox"   # sandbox | production

FACEBOOK_APP_ID="your-fb-app-id"
FACEBOOK_APP_SECRET="your-fb-app-secret"

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Notifications ────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"
POSTHOG_API_KEY="phc_..."
POSTHOG_HOST="https://app.posthog.com"

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
MARKETPLACE_TOKEN_ENCRYPTION_KEY="32-byte-hex-key-for-aes-256"
