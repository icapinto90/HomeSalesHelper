{
  "name": "home-sale-helper-api",
  "version": "0.1.0",
  "description": "Home Sale Helper — Backend API (Fastify + Node.js 22)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/services/publishing/worker-entrypoint.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate:test": "prisma migrate deploy"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@google-cloud/vision": "^4.3.2",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.46.2",
    "bullmq": "^5.28.0",
    "fastify": "^4.28.1",
    "expo-server-sdk": "^3.10.0",
    "ioredis": "^5.4.1",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "stripe": "^17.5.0",
    "zod": "^3.24.1",
    "@sentry/node": "^8.9.2",
    "@sentry/profiling-node": "^8.9.2",
    "posthog-node": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
